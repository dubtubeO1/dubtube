{
  "name": "dubtube",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "concurrently --names \"next,tunnel,worker\" --prefix-colors \"cyan,yellow,magenta\" \"next dev\" \"cloudflared tunnel run dubtube-local\" \"npm run dev --prefix worker\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "echo 'Dependencies installed successfully'"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@clerk/nextjs": "^6.21.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/uuid": "^10.0.0",
    "lucide-react": "^0.509.0",
    "next": "15.3.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^18.5.0",
    "svix": "^1.76.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
